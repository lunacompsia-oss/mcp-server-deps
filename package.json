    "prepare": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "dependencies",
    "outdated",
    "vulnerabilities",
    "security",
    "npm",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "author": "Auto Company <autocompany@lunacompsia.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lunacompsia-oss/mcp-server-deps"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
